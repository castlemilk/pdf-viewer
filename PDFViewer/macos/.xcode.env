# This file is sourced by React Native's Xcode bundle phase. Xcode launched
# from Finder does not inherit shell init files, so resolve Node explicitly.
NODE_RESOLVER=""
if [ -n "${PODS_ROOT:-}" ] && [ -x "${PODS_ROOT}/../../scripts/resolve-node-binary.sh" ]; then
  NODE_RESOLVER="${PODS_ROOT}/../../scripts/resolve-node-binary.sh"
elif [ -n "${SRCROOT:-}" ] && [ -x "${SRCROOT}/../scripts/resolve-node-binary.sh" ]; then
  NODE_RESOLVER="${SRCROOT}/../scripts/resolve-node-binary.sh"
fi

if [ -n "$NODE_RESOLVER" ]; then
  export NODE_BINARY="$("$NODE_RESOLVER")"
else
  export NODE_BINARY="${NODE_BINARY:-$(command -v node || true)}"
fi
