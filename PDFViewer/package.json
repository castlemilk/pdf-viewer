{
  "name": "Acacia",
  "version": "1.0.4",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "macos:build": "xcodebuild -workspace macos/PDFViewer.xcworkspace -scheme PDFViewer-macOS -configuration Debug -destination 'platform=macOS' build CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY=- CODE_SIGN_ENTITLEMENTS= CODE_SIGNING_REQUIRED=NO PROVISIONING_PROFILE_SPECIFIER= DEVELOPMENT_TEAM= ENABLE_HARDENED_RUNTIME=NO",
    "macos:test": "xcodebuild build-for-testing -workspace macos/PDFViewer.xcworkspace -scheme PDFViewer-macOS-Unit -destination 'platform=macOS' -derivedDataPath /tmp/PDFViewerDerivedData && xcrun xctest /tmp/PDFViewerDerivedData/Build/Products/Debug/Acacia-macOSTests.xctest",
    "macos:ui-build": "FORCE_BUNDLING=1 xcodebuild -quiet build-for-testing -workspace macos/PDFViewer.xcworkspace -scheme PDFViewer-macOS-UI -configuration Release -destination 'platform=macOS' -derivedDataPath /tmp/PDFViewerUIDerivedData ONLY_ACTIVE_ARCH=YES ARCHS=$(uname -m) ENABLE_HARDENED_RUNTIME=NO",
    "macos:ui-test": "scripts/run-macos-e2e.sh",
    "macos:pro-purchase-e2e": "scripts/run-macos-pro-purchase-e2e.sh",
    "macos:smoke-window": "scripts/smoke-macos-window.sh /Applications/Acacia.app --uitesting",
    "e2e:macos": "npm run macos:ui-test",
    "ios:ui-test": "scripts/run-ios-e2e.sh",
    "e2e:ios": "npm run ios:ui-test",
    "package:macos": "scripts/package-macos.sh",
    "package:macos:dmg": "scripts/build-release-dmg.sh",
    "package:appstore": "scripts/build-app-store-archive.sh",
    "package:ios:appstore": "scripts/build-ios-app-store-archive.sh",
    "publish:local": "scripts/publish-local.sh",
    "publish:macos": "scripts/publish-macos.sh",
    "publish:appstore": "scripts/publish-app-store.sh",
    "publish:appstore:bundle-id": "scripts/ensure-apple-bundle-id.sh",
    "publish:appstore:rollout": "scripts/rollout-app-store-local.sh",
    "publish:prereqs": "scripts/check-publishing-prereqs.sh",
    "publish:appstore:status": "scripts/check-app-store-status.sh",
    "publish:appstore:wait": "scripts/wait-app-store-build.sh",
    "publish:appstore:attach-build": "scripts/attach-app-store-version-build.sh",
    "publish:ios:appstore:attach-build": "scripts/attach-app-store-version-build.sh --platform IOS",
    "publish:appstore:text": "scripts/upload-app-store-text.sh",
    "publish:appstore:accessibility": "scripts/update-app-store-accessibility.sh",
    "publish:appstore:screenshots": "scripts/upload-app-store-screenshots.sh",
    "publish:appstore:previews": "scripts/upload-app-store-previews.sh",
    "publish:testflight:internal": "scripts/rollout-testflight-internal.sh",
    "publish:ios:testflight:internal": "scripts/rollout-testflight-internal.sh --platform IOS",
    "screenshots:publish": "scripts/capture-publishing-screenshots.sh",
    "screenshots:ios": "scripts/capture-ios-app-store-screenshots.sh",
    "backend:pro:test": "cd backend/pro && go test ./...",
    "backend:pro:proto": "cd backend/pro && protoc -I proto --go_out=. --go_opt=module=github.com/benebsworth/acacia/backend/pro proto/acacia/pro/v1/account.proto",
    "icon:macos": "swift scripts/generate-app-icon.swift",
    "start": "react-native start",
    "test": "jest",
    "typecheck": "tsc --noEmit --pretty false",
    "validate": "npm run lint && npm test -- --runInBand && npm run typecheck && npm run macos:test"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.81.6",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-macos": "^0.81.7",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-svg": "^15.15.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.6",
    "@react-native/eslint-config": "0.81.6",
    "@react-native/metro-config": "0.81.6",
    "@react-native/typescript-config": "0.81.6",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.1.4",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
