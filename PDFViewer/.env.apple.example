# Local Apple publishing credentials for Acacia.
# Copy to .env.apple and fill values locally. This file is safe to commit.

DEVELOPMENT_TEAM=WFTX6CN23F
BUNDLE_ID=com.benebsworth.acacia
APP_STORE_VERSION=1.0.3
APP_STORE_BUILD_NUMBER=

# App Store Connect API key. The private key can be a path or inline value.
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_PRIVATE_KEY_PATH=

# Only needed for altool app-store-text upload/status commands.
